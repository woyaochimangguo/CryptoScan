# Telegram
TG_BOT_TOKEN=
TG_CHAT_ID=

# Storage
CRYPTOSCAN_DB_PATH=./data/cryptoscan.db
CRYPTOSCAN_DATA_DIR=./data

# Scanner thresholds
OI_MIN_CHANGE_PCT=8
OI_DEDUP_HOURS=24
MIN_VOLUME_USDT=1000000

# LLM defaults (used when a role-specific override is not set below)
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=

# --- Role-based LLM routing ---
# Leave empty to fall back to LLM_MODEL/LLM_BASE_URL/OPENAI_API_KEY above.
# Example: strong model for live trading decisions, cheap model for post-mortems.
#   LLM_DECISION_MODEL=claude-sonnet-4-5
#   LLM_DECISION_BASE_URL=https://aihubmix.com/v1
#   LLM_DECISION_API_KEY=
#   LLM_REFLECTION_MODEL=gpt-4o-mini
#   LLM_REFLECTION_BASE_URL=
#   LLM_REFLECTION_API_KEY=
LLM_DECISION_MODEL=
LLM_DECISION_BASE_URL=
LLM_DECISION_API_KEY=
LLM_REFLECTION_MODEL=
LLM_REFLECTION_BASE_URL=
LLM_REFLECTION_API_KEY=

# 6551 MCP servers (optional)
OPENNEWS_TOKEN=
TWITTER_TOKEN=
OPENNEWS_MCP_DIR=
OPENTWITTER_MCP_DIR=

# Binance Futures Testnet (paper trading)
BINANCE_TESTNET_KEY=
BINANCE_TESTNET_SECRET=
PAPER_DEFAULT_SIZE_USDT=100
PAPER_LEVERAGE=5

# Scheduler
SCAN_INTERVAL_MINUTES=5
POSITION_WATCH_INTERVAL_SECONDS=60

# Auto-execute (paper trading)
AUTO_EXECUTE_ENABLED=false
AUTO_EXECUTE_NOTIONAL_USDT=20
AUTO_EXECUTE_MAX_CONCURRENT=3
AUTO_EXECUTE_MIN_FREE_USDT=50
AUTO_EXECUTE_SL_PCT=1.5
AUTO_EXECUTE_TP_PCTS=2.5,5.0
AUTO_EXECUTE_MAX_AGE_MINUTES=10
AUTO_EXECUTE_INTERVAL_SECONDS=30
AUTO_REFLECT_INTERVAL_SECONDS=120
